    {
      "id": "BfOaLTpDu8DoANo7erd2R",
      "type": "text",
      "x": 943.8145136712112,
      "y": 2315.619304654853,
      "width": 993.1036987304688,
      "height": 3045,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bUH",
      "roundness": null,
      "seed": 375379522,
      "version": 62,
      "versionNonce": 230910078,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "-iTUg-mbPCgd9ngn9-Pc-",
          "type": "arrow"
        },
        {
          "id": "xZGGQDpCgblz-TRrHsUgH",
          "type": "arrow"
        }
      ],
      "updated": 1778756175023,
      "link": null,
      "locked": false,
      "text": "void rb_i32_del_fixup(RBTree *tree, RBNode *x, RBNode *parent) {\n    // x 是亏了一个黑的节点\n    // 只要 x 不是根，且 x 是黑色，就需要修\n    while (x != tree->root && (x == tree->NIL || x->color == BLACK)) {\n        \n        // ====== x 是父亲的左孩子 ======\n        if (x == parent->left) {\n            RBNode *bro = parent->right;  // 兄弟在右边\n\n            // 情况A：兄弟是红色\n            if (bro->color == RED) {\n                bro->color = BLACK;\n                parent->color = RED;\n                rb_i32_left_rotate(tree, parent);\n                bro = parent->right;  // 兄弟更新\n            }\n\n            // 现在兄弟一定是黑色\n\n            // 情况B1：兄弟两个孩子全黑\n            if ((bro->left == tree->NIL || bro->left->color == BLACK) &&\n                (bro->right == tree->NIL || bro->right->color == BLACK)) {\n                bro->color = RED;      // 兄弟一起亏\n                x = parent;            // 问题上移\n                parent = x->parent;\n            } \n            // 兄弟至少有一个红孩子\n            else {\n                // 情况B2：远端是黑（即近端是红），先转成B3\n                if (bro->right == tree->NIL || bro->right->color == BLACK) {\n                    // 近端红孩子变黑，兄弟变红，在兄弟处右旋\n                    if (bro->left != tree->NIL)\n                        bro->left->color = BLACK;\n                    bro->color = RED;\n                    rb_i32_right_rotate(tree, bro);\n                    bro = parent->right;  // 兄弟更新\n                }\n\n                // 情况B3：远端是红，终极修复\n                bro->color = parent->color;   // 兄弟继承父亲颜色\n                parent->color = BLACK;        // 父亲变黑\n                if (bro->right != tree->NIL)\n                    bro->right->color = BLACK; // 远端红变黑\n                rb_i32_left_rotate(tree, parent);\n                x = tree->root;  // 修复完成，退出\n            }\n        } \n        \n        // ====== x 是父亲的右孩子（镜像） ======\n        else {\n            RBNode *bro = parent->left;\n\n            if (bro->color == RED) {\n                bro->color = BLACK;\n                parent->color = RED;\n                rb_i32_right_rotate(tree, parent);\n                bro = parent->left;\n            }\n\n            if ((bro->left == tree->NIL || bro->left->color == BLACK) &&\n                (bro->right == tree->NIL || bro->right->color == BLACK)) {\n                bro->color = RED;\n                x = parent;\n                parent = x->parent;\n            } else {\n                if (bro->left == tree->NIL || bro->left->color == BLACK) {\n                    if (bro->right != tree->NIL)\n                        bro->right->color = BLACK;\n                    bro->color = RED;\n                    rb_i32_left_rotate(tree, bro);\n                    bro = parent->left;\n                }\n\n                bro->color = parent->color;\n                parent->color = BLACK;\n                if (bro->left != tree->NIL)\n                    bro->left->color = BLACK;\n                rb_i32_right_rotate(tree, parent);\n                x = tree->root;\n            }\n        }\n    }\n\n    // 最后把 x 染黑（根或上移上来的红节点）\n    if (x != tree->NIL)\n        x->color = BLACK;\n}",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "void rb_i32_del_fixup(RBTree *tree, RBNode *x, RBNode *parent) {\n    // x 是亏了一个黑的节点\n    // 只要 x 不是根，且 x 是黑色，就需要修\n    while (x != tree->root && (x == tree->NIL || x->color == BLACK)) {\n        \n        // ====== x 是父亲的左孩子 ======\n        if (x == parent->left) {\n            RBNode *bro = parent->right;  // 兄弟在右边\n\n            // 情况A：兄弟是红色\n            if (bro->color == RED) {\n                bro->color = BLACK;\n                parent->color = RED;\n                rb_i32_left_rotate(tree, parent);\n                bro = parent->right;  // 兄弟更新\n            }\n\n            // 现在兄弟一定是黑色\n\n            // 情况B1：兄弟两个孩子全黑\n            if ((bro->left == tree->NIL || bro->left->color == BLACK) &&\n                (bro->right == tree->NIL || bro->right->color == BLACK)) {\n                bro->color = RED;      // 兄弟一起亏\n                x = parent;            // 问题上移\n                parent = x->parent;\n            } \n            // 兄弟至少有一个红孩子\n            else {\n                // 情况B2：远端是黑（即近端是红），先转成B3\n                if (bro->right == tree->NIL || bro->right->color == BLACK) {\n                    // 近端红孩子变黑，兄弟变红，在兄弟处右旋\n                    if (bro->left != tree->NIL)\n                        bro->left->color = BLACK;\n                    bro->color = RED;\n                    rb_i32_right_rotate(tree, bro);\n                    bro = parent->right;  // 兄弟更新\n                }\n\n                // 情况B3：远端是红，终极修复\n                bro->color = parent->color;   // 兄弟继承父亲颜色\n                parent->color = BLACK;        // 父亲变黑\n                if (bro->right != tree->NIL)\n                    bro->right->color = BLACK; // 远端红变黑\n                rb_i32_left_rotate(tree, parent);\n                x = tree->root;  // 修复完成，退出\n            }\n        } \n        \n        // ====== x 是父亲的右孩子（镜像） ======\n        else {\n            RBNode *bro = parent->left;\n\n            if (bro->color == RED) {\n                bro->color = BLACK;\n                parent->color = RED;\n                rb_i32_right_rotate(tree, parent);\n                bro = parent->left;\n            }\n\n            if ((bro->left == tree->NIL || bro->left->color == BLACK) &&\n                (bro->right == tree->NIL || bro->right->color == BLACK)) {\n                bro->color = RED;\n                x = parent;\n                parent = x->parent;\n            } else {\n                if (bro->left == tree->NIL || bro->left->color == BLACK) {\n                    if (bro->right != tree->NIL)\n                        bro->right->color = BLACK;\n                    bro->color = RED;\n                    rb_i32_left_rotate(tree, bro);\n                    bro = parent->left;\n                }\n\n                bro->color = parent->color;\n                parent->color = BLACK;\n                if (bro->left != tree->NIL)\n                    bro->left->color = BLACK;\n                rb_i32_right_rotate(tree, parent);\n                x = tree->root;\n            }\n        }\n    }\n\n    // 最后把 x 染黑（根或上移上来的红节点）\n    if (x != tree->NIL)\n        x->color = BLACK;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
